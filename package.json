{
  "name": "ai-review-gate",
  "version": "1.0.0",
  "description": "AGENTS.md 기반 AI Review Gate 데모",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "ai-review": "tsx scripts/ai-review.ts",
    "ai-review:mock": "AI_REVIEW_MOCK=1 tsx scripts/ai-review.ts",
    "ai-review:ci": "tsx scripts/ai-review.ts --ci"
  },
  "dependencies": {
    "express": "^4.21.2",
    "openai": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  },
  "private": true
}
